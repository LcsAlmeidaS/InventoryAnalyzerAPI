# URL base da API consumida pelo frontend (sem barra final)
# Em desenvolvimento o Vite proxy encaminha /api → BACKEND_URL, então mantenha /api
# Em produção aponte para a URL pública da API: https://sua-api.com/api
VITE_API_URL=/api

# URL do backend usada pelo proxy do Vite (apenas em desenvolvimento)
BACKEND_URL=http://localhost:5122
