```ignore
# Build folders
bin/
obj/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# User-specific files
*.user
*.suo
*.userprefs

# Rider
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ASP.NET Core
appsettings.Development.json

# Publish output
publish/

# Test results
TestResults/

# NuGet
*.nupkg
packages/

# VS temporary files
*.tmp
*.temp

# Coverage reports
coverage/

# Frontend - Node modules
node_modules/

# Frontend - Build output
dist/
dist-ssr/

# Backup files
*.bak

# Dotnet tools
.dotnet/

# Local database files
*.db
*.sqlite
*.sqlite3
```